import os
import google.generativeai as genai
import json
import re
import random

genai.configure(api_key=os.environ.get("GOOGLE_API_KEY"))
model = genai.GenerativeModel('gemini-1.5-flash')

def evaluate_answer(student_answer, question_text):
    # Prompt này ép AI phải thay đổi cách hành văn, không được lặp lại
    prompt = f"""
    You are a friendly and professional English teacher. 
    Analyze the student's answer: "{student_answer}" for the question: "{question_text}"

    CRITICAL RULES:
    1. DO NOT use repetitive phrases like "Em cần chú ý mạo từ" or "Cố gắng lên".
    2. BE SPECIFIC: If they made a mistake, explain exactly WHERE and WHY in Vietnamese.
    3. IF PERFECT: Congratulate them with variety and suggest a more "native/advanced" way to say it.
    4. TONE: Warm, encouraging, and natural (like a real conversation).

    Return ONLY a JSON object:
    {{
        "score": (number 0-10),
        "feedback": "[A unique opening comment about their idea] <br><b>Sửa lỗi:</b> [Specific analysis or 'Perfect!'] <br><b>Native Speaker Version:</b> [An advanced version of their answer]"
    }}
    """
    try:
        # Sử dụng tham số generation_config để AI sáng tạo hơn, bớt rập khuôn
        res = model.generate_content(
            prompt,
            generation_config=genai.types.GenerationConfig(
                temperature=0.8, # Tăng độ "phiêu" cho ngôn ngữ
                top_p=0.95,
            )
        )
        match = re.search(r'\{.*\}', res.text, re.DOTALL)
        if match:
            data = json.loads(match.group())
            return {
                "score": float(data.get("score", 7.5)),
                "feedback": data.get("feedback", "Ý tưởng của em rất hay, cô đánh giá cao sự sáng tạo này!")
            }
        raise Exception("JSON not found")
    except:
        # Bản dự phòng nếu API lỗi cũng phải đa dạng
        backups = [
            "Cách em dùng từ rất thú vị, hãy tiếp tục phát huy nhé!",
            "Câu trả lời rất đi vào trọng tâm, cô rất thích!",
            "Một góc nhìn mới mẻ! Em thử dùng thêm các trạng từ để câu mềm mại hơn xem sao."
        ]
        return {"score": 8.0, "feedback": random.choice(backups)}

def get_encouraging_message():
    # Lời khen ngắn hiện trên màn hình cũng phải đổi mới
    messages = ["Brilliant! 🌟", "Keep it up! 🚀", "So natural! ✨", "Impressive! 🔥", "You nailed it! 🎯"]
    return random.choice(messages)
